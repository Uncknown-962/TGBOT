# Telegram Bot Configuration

# Bot token from @BotFather (required)
BOT_TOKEN=your_bot_token_here

# Admin Telegram IDs separated by comma (required)
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# Database URL (optional, default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./database/bot.db

# Redis configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Logging level (optional, default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Webhook settings (optional, for production)
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
